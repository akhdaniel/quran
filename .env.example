# DeepSeek API key untuk fitur Analisa Ayat
# Set di Vercel Dashboard > Environment Variables agar dibundle saat build
# Atau isi di sini untuk local dev
VITE_DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Vercel Blob (untuk backend penyimpanan analisa ayat)
# Auto-terisi saat bikin Blob Store di Vercel Dashboard > Storage
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
