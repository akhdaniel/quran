# DeepSeek API key untuk fitur Analisa Ayat
# -------------------------------------------------------
# LOCAL DEV: Copy file ini ke .env, isi key kamu
#   VITE_DEEPSEEK_API_KEY=sk-xxx
#
# VERCEL: Set di Dashboard > Environment Variables
#   DEEPSEEK_API_KEY=sk-xxx
#   (VITE_DEEPSEEK_API_KEY juga bisa, dua-duanya didukung)
# -------------------------------------------------------
VITE_DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
